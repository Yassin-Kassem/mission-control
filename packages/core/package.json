{
  "name": "@mctl/core",
  "version": "0.1.0",
  "description": "Mission Control core engine — signals, memory, drones, and mission lifecycle",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": ["dist"],
  "license": "MIT",
  "publishConfig": { "access": "public" },
  "keywords": ["claude", "ai", "orchestration", "mission-control", "drones"],
  "scripts": {
    "build": "tsc && node -e \"const fs=require('fs'),p=require('path');function cp(s,d){fs.mkdirSync(d,{recursive:true});for(const e of fs.readdirSync(s,{withFileTypes:true})){const sp=p.join(s,e.name),dp=p.join(d,e.name);e.isDirectory()?cp(sp,dp):fs.copyFileSync(sp,dp)}}cp('src/drones/builtin','dist/drones/builtin')\"",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src/"
  },
  "dependencies": {
    "better-sqlite3": "^11.0.0",
    "yaml": "^2.0.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.0.0",
    "vitest": "^3.0.0",
    "typescript": "^5.7.0"
  }
}
